PORT=5000
NODE_ENV=development

# --- MongoDB (pick ONE) ---
#
# A) Local with Docker (from repo root: Shakti-Shield):
#    Start Docker Desktop, then:  docker compose up -d
#    Keep this URI:
MONGO_URI=mongodb://127.0.0.1:27017/shakti-shield
#
# B) MongoDB Atlas (no Docker):
#    1) https://www.mongodb.com/atlas → free cluster → Database → Connect → Drivers
#    2) Copy the SRV string; replace <password> with your DB user password
#    3) Append a database name, e.g. ...mongodb.net/shakti-shield?retryWrites=true&w=majority
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/shakti-shield?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-string-in-production
GOOGLE_CLIENT_ID=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET=
FAST2SMS_API_KEY=
